{
  "group_interval": 1000,
  "tag_regex": [
    {
      "type": 1,
      "regex": "^([0-9]+![is]=.+|ns=[0-9]+;[is]=.+)$"
    },
    {
      "type": 5,
      "regex": "^([0-9]+![is]=.+|ns=[0-9]+;[is]=.+)$"
    },
    {
      "type": 6,
      "regex": "^([0-9]+![is]=.+|ns=[0-9]+;[is]=.+)$"
    },
    {
      "type": 9,
      "regex": "^([0-9]+![is]=.+|ns=[0-9]+;[is]=.+)$"
    },
    {
      "type": 10,
      "regex": "^([0-9]+![is]=.+|ns=[0-9]+;[is]=.+)$"
    },
    {
      "type": 12,
      "regex": "^([0-9]+![is]=.+|ns=[0-9]+;[is]=.+)$"
    },
    {
      "type": 13,
      "regex": "^([0-9]+![is]=.+|ns=[0-9]+;[is]=.+)$"
    }
  ],
  "endpoint": {
    "name": "Endpoint URL",
    "name_zh": "端点地址",
    "attribute": "required",
    "type": "string",
    "default": "opc.tcp://127.0.0.1:4840/"
  },
  "timeout": {
    "name": "Connection Timeout (ms)",
    "name_zh": "连接超时 (ms)",
    "attribute": "required",
    "type": "int",
    "default": 5000,
    "valid": {
      "min": 500,
      "max": 60000
    }
  },
  "enable_auth": {
    "name": "Enable Username/Password",
    "name_zh": "启用用户名密码认证",
    "attribute": "required",
    "type": "map",
    "default": 0,
    "valid": {
      "map": [
        { "key": "False", "value": 0 },
        { "key": "True", "value": 1 }
      ]
    }
  },
  "username": {
    "name": "Username",
    "name_zh": "用户名",
    "attribute": "required",
    "type": "string",
    "condition": { "field": "enable_auth", "value": 1 }
  },
  "password": {
    "name": "Password",
    "name_zh": "密码",
    "attribute": "required",
    "type": "string",
    "condition": { "field": "enable_auth", "value": 1 }
  },
  "read_mode": {
    "name": "Read mode",
    "name_zh": "读取模式",
    "attribute": "optional",
    "type": "int",
    "default": 0,
    "valid": {
      "min": 0,
      "max": 1
    }
  },
  "publish_interval": {
    "name": "Publish / poll interval (ms)",
    "name_zh": "发布/轮询间隔 (ms)",
    "attribute": "optional",
    "type": "int",
    "default": 500,
    "valid": {
      "min": 100,
      "max": 3600000
    }
  }
}

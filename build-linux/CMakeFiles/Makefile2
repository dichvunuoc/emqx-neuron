	$(CMAKE_COMMAND) -E cmake_progress_start /workspace/build-linux/CMakeFiles 31
	$(MAKE) -f CMakeFiles/Makefile2 tests/plugins/demo_app/CMakeFiles/plugin-demo_app.dir/all
	$(CMAKE_COMMAND) -E cmake_progress_start /workspace/build-linux/CMakeFiles 0
.PHONY : tests/plugins/demo_app/CMakeFiles/plugin-demo_app.dir/rule

# Convenience name for target.
plugin-demo_app: tests/plugins/demo_app/CMakeFiles/plugin-demo_app.dir/rule

.PHONY : plugin-demo_app

# clean rule for target.
tests/plugins/demo_app/CMakeFiles/plugin-demo_app.dir/clean:
	$(MAKE) -f tests/plugins/demo_app/CMakeFiles/plugin-demo_app.dir/build.make tests/plugins/demo_app/CMakeFiles/plugin-demo_app.dir/clean
.PHONY : tests/plugins/demo_app/CMakeFiles/plugin-demo_app.dir/clean

#=============================================================================
# Special targets to cleanup operation of make.

# Special rule to run CMake to check the build system integrity.
# No rule that depends on this can have commands that come from listfiles
# because they might be regenerated.
cmake_check_build_system:
	$(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
.PHONY : cmake_check_build_system


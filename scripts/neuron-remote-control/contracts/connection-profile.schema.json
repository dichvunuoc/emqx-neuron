{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/neuron/remote-control/connection-profile.schema.json",
  "title": "NeuronReverseConnectionProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "enabled",
    "gatewayId",
    "controlServerUrl",
    "authMode",
    "heartbeatSec",
    "reconnectSec",
    "updatedAt"
  ],
  "properties": {
    "enabled": { "type": "boolean" },
    "gatewayId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9._-]{3,128}$"
    },
    "controlServerUrl": {
      "type": "string",
      "pattern": "^wss://"
    },
    "authMode": {
      "type": "string",
      "enum": ["mtls", "mtls_hmac"]
    },
    "hmacEnabled": { "type": "boolean", "default": false },
    "heartbeatSec": { "type": "integer", "minimum": 5, "maximum": 120 },
    "reconnectSec": { "type": "integer", "minimum": 1, "maximum": 60 },
    "dryRunDefault": { "type": "boolean", "default": true },
    "description": { "type": "string", "maxLength": 512 },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
